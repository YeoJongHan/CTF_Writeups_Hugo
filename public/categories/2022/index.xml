 &lt;div hidden data-code-source&gt;from Crypto.Util.number import getPrime, getRandomRange, bytes_to_long

FLAG = bytes_to_long(open(&amp;#34;flag.txt&amp;#34;, &amp;#34;rb&amp;#34;).read())
N = FLAG.bit_length() &amp;#43; 2**7

m = sorted([ getPrime(N) for _ in range(5) ])
share = []

while ((m[1]*m[2]*m[3] &amp;lt; m[0]*m[3]*m[4]) and m[4]&amp;lt;m[3]):
	m[4] = getPrime(N)

M = m[1]*m[2]
alpha = getRandomRange(2, M)
k = 4

for i in range(k):
 s = (FLAG &amp;#43; alpha*m[0]) % m[i&amp;#43;1]
 share.append(s)

with open(&amp;#34;out.txt&amp;#34;, &amp;#39;w&amp;#39;) as f:
 f.write(f&amp;#34;Public (m0): {hex(m[0])}\n\n&amp;#34;)

 for i in range(len(share)):
 f.write(f&amp;#34;Share {i} (s{i}, m{i&amp;#43;1}): ({hex(share[i])}, {hex(m[i&amp;#43;1])})\n&amp;#34;)&lt;/div&gt;
 
